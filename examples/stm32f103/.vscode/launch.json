{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "probe-rs-debug",
      "request": "launch",
      "name": "probe-rs debug",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "build",
      "connectUnderReset": false,
      "chip": "STM32F103C8",
      "flashingConfig": {
        "flashingEnabled": true,
        "haltAfterReset": false
      },
      "coreConfigs": [
        {
          "coreIndex": 0,
          "programBinary": "./target/thumbv7m-none-eabi/debug/stm32f103"
        }
      ]
    }
  ]
}
